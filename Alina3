import gradio as gr
import tempfile
import os

# Импортируем основную функцию из файла main.py
from main import search_scenes_in_video

def search_movie(query_text, video_file):
    """
    Обработчик событий интерфейса.
    """
    # Сохраняем загруженный файл во временный файл на диске,
    # так как функция поиска ожидает путь к файлу.
    with tempfile.NamedTemporaryFile(suffix='.mp4', delete=False) as tmp_file:
        video_file.save(tmp_file.name)
        
        # Вызываем основную логику поиска
        result = search_scenes_in_video(query_text, tmp_file.name)
        
        # Удаляем временный файл после обработки
        os.unlink(tmp_file.name)
        
    return result

# Создаем интерфейс Gradio
iface = gr.Interface(
    fn=search_movie,
    inputs=[
        gr.Textbox(label="Опишите сцену из фильма", placeholder="Например: погоня на машинах"),
        gr.Video(label="Выберите видеофайл", format="mp4")
     ],
     outputs="text",
     title="Поиск сцен в фильмах по описанию",
     description="Введите описание сцены и загрузите видеофайл. Приложение найдет наиболее подходящие моменты.",
     allow_flagging="never"
)

# Запускаем интерфейс. Hugging Face сам вызовет эту функцию.
if __name__ == "__main__":
    iface.launch()
