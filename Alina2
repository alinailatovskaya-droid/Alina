(query_text, video_file_path):
    """
    Основная функция для вызова из интерфейса.
    Принимает текст запроса и путь к файлу.
    """
    device = 'cuda' if torch.cuda.is_available() else 'cpu'
    
    if device == 'cpu':
        return {"error": "GPU (CUDA) не обнаружен. Поиск на CPU будет очень медленным."}

    model, preprocess = load_clip_model(device)
    if model is None:
        return {"error": "Не удалось загрузить модель CLIP."}

    try:
        frames, timestamps = extract_frames(video_file_path)
        if not frames:
            return {"error": "Не удалось извлечь кадры из видео."}

        query_vec = encode_text(model, query_text, device)
        image_vecs = encode_images(model, frames, preprocess, device=device)

        matches = search_scenes(query_vec, image_vecs, timestamps)
        
        # Формируем красивый вывод для пользователя
        output_text = "Найдены следующие моменты:\n"
        for match in matches:
            output_text += f"- Время: {match['timecode']} (сходство: {match['score']:.2f})\n"
            
        return output_text

    except Exception as e:
